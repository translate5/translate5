            </trans-unit>
            <trans-unit id="VGhlIGZpbGUg4oCce2ZpbGV94oCdIGhhcyBhbiBpbnZhbGlkIHR5cGU=">
                <source>The file “{file}” has an invalid type</source>
                <target>The file “{file}” has an invalid type</target>
