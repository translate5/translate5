            <trans-unit id="VGhlIHRhc2sgaXMgaW4gdXNlIGFuZCB0aGVyZWZvcmUgY2Fubm90IGJlIGRlbGV0ZWQu">
                <source>The task is in use and therefore cannot be deleted.</source>
                <target>Die Aufgabe wird von einem Benutzer benutzt, und kann daher nicht gelöscht werden.</target>
            </trans-unit>
            <trans-unit id="VGhlIHRhc2sgaXMgbG9ja2VkIGJ5IGEgdXNlciBhbmQgY2Fubm90IGJlIGRlbGV0ZWQgdGhlcmVmb3JlISE=">
                <source>The task is locked by a user and cannot be deleted therefore!!</source>
                <target>Die Aufgabe ist durch einen Benutzer gesperrt, und kann daher nicht gelöscht werden.</target>
            </trans-unit>
            <trans-unit id="VGhlIHRhc2sgc3RpbGwgY29udGFpbnMgc2VnbWVudHMgaW4gZHJhZnQgc3RhdHVzLiBDaGFuZ2UgdGhlIHN0YXR1cyB0byBmaW5hbCBhbmQgZmluaXNoIHRoZSB0YXNrIHRoZW4u">
                <source>The task still contains segments in draft status. Change the status to final and finish the task then.</source>
                <target>Die Aufgabe enthält noch Segmente im Entwurfsstatus. Setzen Sie den Status auf final um und beenden Sie dann die Aufgabe.</target>
            </trans-unit>
            <trans-unit id="VGhlIHRhc2sgc3RpbGwgY29udGFpbnMgc2VnbWVudHMgaW4gZHJhZnQgc3RhdHVzLiBPcGVuIHRoZSB0YXNrIGFuZCBjaGFuZ2UgdGhlIHN0YXR1cy4=">
                <source>The task still contains segments in draft status. Open the task and change the status.</source>
                <target>Die Aufgabe enthält noch Segmente im Entwurfsstatus. Öffnen Sie die Aufgabe und setzen Sie den Status um.</target>
            </trans-unit>
            <trans-unit id="VGhlIHRhc2sgd2FzIHVwZGF0ZWQgc3VjY2Vzc2Z1bGx5">
                <source>The task was updated successfully</source>
                <target>Die Aufgabe wurde erfolgreich aktualisiert</target>
            </trans-unit>
            <trans-unit id="VGhlIHRhc2sg4oCcJXPigJ0gaXMg4oCcJXPigJ0gJXMgb3ZlcmR1ZSE=">
                <source>The task “%s” is “%s” %s overdue!</source>
                <target>Die Aufgabe „%s“ ist „%s“ %s überfällig!</target>
            </trans-unit>
            <trans-unit id="VGhlIHRvIGJlIHJlbW92ZWQgbGFuZ3VhZ2UgcmVzb3VyY2UgaXMgdXNlZCBpbiB0aGUgZm9sbG93aW5nIHRhc2tzOg==">
                <source>The to be removed language resource is used in the following tasks:</source>
                <target>Die zu löschende Sprachressource wird von folgenden Aufgaben benutzt:</target>
            </trans-unit>
