            <trans-unit id="RW5kIHZhbHVlIG11c3QgYmUgYmlnZ2VyIG9yIGVxdWFsIHRvIHN0YXJ0IHZhbHVlIQ==">
                <source>End value must be bigger or equal to start value!</source>
                <target>Der Endwert muss größer oder gleich dem Startwert sein!</target>
            </trans-unit>
            <trans-unit id="RXhhY3QgZXhhY3QgTWF0Y2ggKDEwMSUp">
                <source>Exact exact Match (101%)</source>
                <target>Exakter Exact-Match (101%)</target>
            </trans-unit>
            <trans-unit id="RXhwb3J0IGFzIEV4Y2Vs">
                <source>Export as Excel</source>
                <target>Export in Excel</target>
            </trans-unit>
            <trans-unit id="RXhwb3J0IGluIFRyYWRvcy1zdHlsZSBYTUw=">
