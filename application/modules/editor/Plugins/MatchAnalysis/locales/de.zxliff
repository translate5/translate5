                <source>Repetitions</source>
                <target>Wiederholungen</target>
            </trans-unit>
            <trans-unit id="UmVwZXRpdGlvbnM6">
                <source>Repetitions:</source>
                <target>Wiederholungen:</target>
            </trans-unit>
            <trans-unit id="U2VhcmNoIGZvciBwcmljZSBvciBsYW5ndWFnZQ==">
