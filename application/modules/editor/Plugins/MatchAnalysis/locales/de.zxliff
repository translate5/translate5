                <target>Match-Rate TM-Vorübersetzung</target>
            </trans-unit>
            <trans-unit id="VFFFIGRlZmF1bHQ=">
                <source>TQE default</source>
                <target></target>
            </trans-unit>
            <trans-unit id="VGVtcGxhdGUgc2VsZWN0ZWQgYnkgZGVmYXVsdCBmb3IgVFFFIGFuYWx5c2lzIC0gdW5sZXNzIG92ZXJyaWRkZW4gYXQgdGhlIGN1c3RvbWVyIGxldmVs">
                <source>Template selected by default for TQE analysis - unless overridden at the customer level</source>
                <target></target>
            </trans-unit>
            <trans-unit id="VGVtcGxhdGUgc2VsZWN0ZWQgYnkgZGVmYXVsdCBmb3IgdGhpcyBjdXN0b21lcuKAmHMgVFFFIGFuYWx5c2lz">
                <source>Template selected by default for this customer‘s TQE analysis</source>
                <target></target>
            </trans-unit>
            <trans-unit id="VGVybUNvbGxlY3Rpb24gbWF0Y2ggKDEwNCUp">
