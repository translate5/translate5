            </trans-unit>
            <trans-unit id="TG9ja2VkIDEwMCUgbWF0Y2hlcyBhcmUgbm90IHBhcnQgb2YgdGhlIGFuYWx5c2lzLg==">
                <source>Locked 100% matches are not part of the analysis.</source>
                <target>Gesperrte 100%-Matches sind nicht Teil der Analyse.</target>
            </trans-unit>
            <trans-unit id="TWF0Y2ggYW5hbHlzaXM=">
                <source>Match analysis</source>
                <target>Trefferanalyse</target>
            </trans-unit>
            <trans-unit id="TWF0Y2ggYW5hbHlzaXMgYW5kIHByZS10cmFuc2xhdGlvbnMgaW4gcHJvZ3Jlc3Mu">
                <source>Match analysis and pre-translations in progress.</source>
                <target>Match-Analyse und Vorübersetzungen werden ausgeführt.</target>
            </trans-unit>
            <trans-unit id="TWF0Y2ggcmFuZ2VzICZhbXA7IHByaWNlcyBpbiBwcmVzZXQ=">
                <source>Match ranges &amp; prices in preset</source>
                <target>Match-Bereiche &amp; Preise in Vorlage</target>
            </trans-unit>
            <trans-unit id="TWF0Y2ggcmFuZ2VzICZhbXA7IHByaWNpbmc=">
                <source>Match ranges &amp; pricing</source>
                <target>Match-Bereiche &amp; Preise</target>
            </trans-unit>
            <trans-unit id="Tm8gYW5hbHlzaXMgaGFzIGJlZW4gY3JlYXRlZCB5ZXQuIFBsZWFzZSBzdGFydCBhbiBhbmFseXNpcyBpbiB0aGUg4oCcTGFuZ3VhZ2UgcmVzb3VyY2Vz4oCdIHRhYg==">
                <source>No analysis has been created yet. Please start an analysis in the “Language resources” tab</source>
                <target>Es wurde bisher keine Analyse erstellt. Starten Sie eine Analyse im Tab „Sprachressourcen zuweisen“.</target>
