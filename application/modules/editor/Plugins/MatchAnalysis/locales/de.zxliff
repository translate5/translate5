                <target>Der Startwert muss kleiner oder gleich dem Endwert sein!</target>
            </trans-unit>
            <trans-unit id="U3Vt">
                <source>Sum</source>
                <target>Summe</target>
            </trans-unit>
            <trans-unit id="U3VtOg==">
                <source>Sum:</source>
                <target>Summe:</target>
            </trans-unit>
