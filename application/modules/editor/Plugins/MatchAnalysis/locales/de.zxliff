                <target>Endgültiger Betrag</target>
            </trans-unit>
            <trans-unit id="RmluaXNo">
                <source>Finish</source>
                <target>Beenden</target>
            </trans-unit>
            <trans-unit id="RnJvbQ==">
                <source>From</source>
                <target>Von</target>
            </trans-unit>
            <trans-unit id="RnJvbSBpbXBvcnRlZCBmaWxl">
                <source>From imported file</source>
                <target>Aus importierter Datei</target>
            </trans-unit>
            <trans-unit id="SWYgdGhpcyBvcHRpb24gaXMgYWN0aXZhdGVkLCB0aGUgc2VnbWVudHMgbm90IHByZS10cmFuc2xhdGVkIHdpdGggdGhlIFRNIHdpbGwgYmUgcHJlLXRyYW5zbGF0ZWQgd2l0aCB0aGUgTVQu">
                <source>If this option is activated, the segments not pre-translated with the TM will be pre-translated with the MT.</source>
                <target>Ist diese Option aktiviert, werden die nicht mit dem TM vorübersetzten Segmente mit der MT vorübersetzt.</target>
            </trans-unit>
            <trans-unit id="SW5jbHVkZXMgYSBRQSBhbmQgdGVybWlub2xvZ3kgY2hlY2s=">
