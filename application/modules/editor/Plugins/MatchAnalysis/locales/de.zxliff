    <file original="php-sourcecode" source-language="en" target-language="de" datatype="php">
        <body>
            <trans-unit id="QWRqdXN0IHByaWNlIGJ5">
                <source>Adjust price by</source>
                <target>Preisanpassung</target>
            </trans-unit>
            <trans-unit id="QW5hbHlzaXM=">
                <source>Analysis</source>
                <target>Analyse</target>
            </trans-unit>
            <trans-unit id="QW5hbHlzaXMgaW4gcHJvZ3Jlc3M=">
                <source>Analysis in progress</source>
                <target>Analyse läuft</target>
            </trans-unit>
            <trans-unit id="QW5hbHlzaXMgc2hvdWxkIGJlIHJlLXJ1biBmb3IgcGVuYWx0aWVzIHRvIGJlIHNhdmVkIGFuZCB0YWtlIGVmZmVjdA==">
                <source>Analysis should be re-run for penalties to be saved and take effect</source>
                <target>Die Analyse muss erneut durchgeführt werden, damit die Match-Rate-Abzüge gespeichert und wirksam werden.</target>
            </trans-unit>
            <trans-unit id="QSBwcmUtdHJhbnNsYXRpb24gYWxzbyB0cmlnZ2VycyBhIG5ldyBhbmFseXNpcw==">
                <source>A pre-translation also triggers a new analysis</source>
                <target>Die Vorübersetzung löst auch eine neue Analyse aus</target>
            </trans-unit>
            <trans-unit id="QXJlIHlvdSBzdXJlIHlvdSB3YW50IHRvIGRlbGV0ZSBwcmljZXMgZm9yIHRoaXMgbGFuZ3VhZ2UgcGFpcj8=">
                <source>Are you sure you want to delete prices for this language pair?</source>
                <target>Sind Sie sicher, dass Sie die Preise für diese Sprachkombination löschen möchten?</target>
            </trans-unit>
            <trans-unit id="QXJlIHlvdSBzdXJlIHlvdSB3YW50IHRvIGRlbGV0ZSB0aGUgcHJpY2luZyBwcmVzZXQg4oCce25hbWV94oCdPw==">
                <source>Are you sure you want to delete the pricing preset “{name}”?</source>
                <target></target>
            </trans-unit>
            <trans-unit id="QXNzb2NpYXRlIGxhbmd1YWdlIHJlc291cmNlcw==">
                <source>Associate language resources</source>
                <target>Sprachressourcen zuweisen</target>
            </trans-unit>
            <trans-unit id="QmFzZWQgb24=">
                <source>Based on</source>
                <target>Basiert auf</target>
            </trans-unit>
            <trans-unit id="Q2xpY2sgb24gdGhlIGNvbHVtbiBoZWFkaW5ncyB0byBlZGl0IHRoZSBtYXRjaCByYW5nZXM=">
                <source>Click on the column headings to edit the match ranges</source>
                <target>Klicken Sie auf die Spaltenüberschriften, um die Match-Bereiche zu bearbeiten.</target>
            </trans-unit>
            <trans-unit id="Q2xpZW50IGRlZmF1bHQ=">
                <source>Client default</source>
                <target>Kundenstandard</target>
            </trans-unit>
            <trans-unit id="Q2xvbmU=">
