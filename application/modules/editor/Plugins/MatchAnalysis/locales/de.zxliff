                <target>Diese Sprachressource wurde entfernt (ID: %s)</target>
            </trans-unit>
            <trans-unit id="VGhpcyB2YWx1ZSBvdmVybGFwcyB0aGUgcmFuZ2U=">
                <source>This value overlaps the range</source>
                <target>Dieser Wert überlappt den Bereich</target>
            </trans-unit>
            <trans-unit id="VG8=">
                <source>To</source>
                <target>Bis</target>
            </trans-unit>
            <trans-unit id="VXNlIFRNIG1hdGNoZXMgYXQgb3IgYWJvdmUgdGhlIHNlbGVjdGVkIHRocmVzaG9sZCBmb3IgcHJlLXRyYW5zbGF0aW9u">
                <source>Use TM matches at or above the selected threshold for pre-translation</source>
                <target>Vorübersetzen mit TM-Matches, die höher oder gleich dem ausgewählten Wert sind</target>
            </trans-unit>
            <trans-unit id="V2l0aCBpbnRlcm5hbCBmdXp6eSBtYXRjaGVz">
                <source>With internal fuzzy matches</source>
                <target>Mit internen Fuzzy-Matches</target>
