            <trans-unit id="Tm8gR2xvYmFsZXNlIHRyYW5zbGF0aW9uIGVuZ2luZSBhdmFpbGFibGUgKGZvciB5b3VyIEdsb2JhbGVzZSB1c2VybmFtZSBhbmQgbGFuZ3VhZ2UgcGFpcikuIFBsZWFzZSBjaGFuZ2UgdGhlIEdsb2JhbGVzZSB1c2VybmFtZSBvciBza2lwIHByZS10cmFuc2xhdGlvbi4=">
                <source>No Globalese translation engine available (for your Globalese username and language pair). Please change the Globalese username or skip pre-translation.</source>
                <target>Nessun motore di traduzione Globalese disponibile (per l’utente Globalese e la combinazione linguistica in questione). Cambiare l’utente o saltare la pretraduzione.</target>
