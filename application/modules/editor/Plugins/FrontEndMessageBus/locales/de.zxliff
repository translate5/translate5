<xliff xmlns="urn:oasis:names:tc:xliff:document:1.1" version="1.1">
    <file original="php-sourcecode" source-language="en" target-language="de" datatype="php">
        <body>
            <trans-unit id="QW5vdGhlciB1c2VyIHdhcyBxdWlja2VyIGFuZCBoYXMgY3VycmVudGx5IGxvY2tlZCB0aGUgc2VnbWVudCBmb3IgZWRpdGluZy4=">
                <source>Another user was quicker and has currently locked the segment for editing.</source>
                <target>Ein anderer Benutzer war schneller und hat das Segment im Moment zur Bearbeitung gesperrt.</target>
            </trans-unit>
            <trans-unit id="Q3VycmVudCBlZGl0b3I=">
                <source>Current editor</source>
                <target>Aktueller Bearbeiter</target>
            </trans-unit>
            <trans-unit id="RWRpdG9yczo=">
                <source>Editors:</source>
                <target>Bearbeiter</target>
            </trans-unit>
            <trans-unit id="TXlzZWxm">
                <source>Myself</source>
                <target>Ich</target>
            </trans-unit>
            <trans-unit id="UmVvcGVu">
                <source>Reopen</source>
                <target>Erneut öffnen</target>
            </trans-unit>
            <trans-unit id="U2VnbWVudCBhbHJlYWR5IGluIHVzZQ==">
                <source>Segment already in use</source>
                <target>Segment bereits in Bearbeitung</target>
            </trans-unit>
            <trans-unit id="U2VnbWVudCB3YXMgY2hhbmdlZCBvbiBzZXJ2ZXIgc2lkZQ==">
                <source>Segment was changed on server side</source>
                <target>Segment wurde auf Serverseite geändert</target>
            </trans-unit>
            <trans-unit id="U2VnbWVudCB3YXMgY2hhbmdlZCBvbiBzZXJ2ZXIgc2lkZS48YnIvPjxici8+PGI+U291cmNlIHRleHQ6PC9iPjxici8+e3NvdXJjZX08YnIvPjxici8+PGI+VGFyZ2V0IHRleHQ6PC9iPjxici8+e3RhcmdldH08YnIvPjxici8+RG8geW91IHdhbnQgdG8gYWNjZXB0IGNoYW5nZXM/">
                <source>Segment was changed on server side.<br/><br/><b>Source text:</b><br/>{source}<br/><br/><b>Target text:</b><br/>{target}<br/><br/>Do you want to accept changes?</source>
                <target>Segment wurde auf Serverseite geändert.<br/><br/><b>Quelltext:</b><br/>{source}<br/><br/><b>Zieltext:</b><br/>{target}<br/><br/>Möchten Sie die Änderungen akzeptieren?</target>
            </trans-unit>
            <trans-unit id="U2VsZWN0ZWQgYnk=">
                <source>Selected by</source>
                <target>Ausgewählt von</target>
            </trans-unit>
            <trans-unit id="VGFzayBjbG9zZWQgaW4gYW5vdGhlciB3aW5kb3c=">
                <source>Task closed in another window</source>
                <target>Aufgabe in anderem Fenster geschlossen</target>
            </trans-unit>
            <trans-unit id="VGhlIHNlbGVjdGVkIHNlZ21lbnQgaXMgYWxyZWFkeSBpbiB1c2UgYnkgYW5vdGhlciB1c2VyIGFuZCBjYW5ub3QgYmUgb3BlbmVkLg==">
                <source>The selected segment is already in use by another user and cannot be opened.</source>
                <target>Das ausgewählte Segment wird bereits von einem anderen Benutzer bearbeitet und kann daher nicht geöffnet werden.</target>
            </trans-unit>
            <trans-unit id="V2l0aG91dCBhIGNvbm5lY3Rpb24gdG8gdGhlIHNlcnZlciwgeW91IGNhbm5vdCBlZGl0IGEgc2VnbWVudC4=">
                <source>Without a connection to the server, you cannot edit a segment.</source>
                <target>Sie können kein Segment editieren, solange keine Verbindung zum Server besteht.</target>
            </trans-unit>
            <trans-unit id="">
                <source>You are experiencing connection problems. <br />Please check the stability of your Internet connection. <br />If you keep seeing this message, it may also indicate <br />that the WebSocket protocol (wss://) is blocked by your firewall.</source>
                <target>Sie haben Verbindungsprobleme zum Internet. <br />Bitte prüfen Sie die Stabilität Ihrer Internetverbindung. <br />Sollte diese Meldung dauerhaft zu sehen sein, kann es auch sein, <br />dass in Ihrer Firewall das Websocket-Protokoll wss:// blockiert ist.</target>
            </trans-unit>
            <trans-unit id="WW91IGhhdmUgY2xvc2VkIHRoZSB0YXNrIGluIGFub3RoZXIgd2luZG93LiBQbGVhc2UgY2xvc2UgdGhpcyB3aW5kb3cgdG9vLCBvciByZWxvYWQgaXQgdG8gcmVvcGVuIHRoZSB0YXNrLg==">
                <source>You have closed the task in another window. Please close this window too, or reload it to reopen the task.</source>
                <target>Sie haben die Aufgabe in anderem Fenster geschlossen. Schließen Sie dieses Fenster ebenfalls, oder laden Sie das Fenster neu, um die Aufgabe erneut zu öffnen.</target>
            </trans-unit>
        </body>
